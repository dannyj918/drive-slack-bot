# ============================================================
# Slack Drive Bot — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================


# ─── SLACK ───────────────────────────────────────────────────
# Bot token  →  api.slack.com/apps → Your App → OAuth & Permissions
#               Copy "Bot User OAuth Token"  (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token  →  api.slack.com/apps → Your App → Basic Information
#                     → App-Level Tokens → Create Token
#                     Scope required: connections:write  (starts with xapp-)
SLACK_APP_TOKEN=xapp-your-app-token-here


# ─── ANTHROPIC ───────────────────────────────────────────────
# API key  →  console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Model (optional — defaults to claude-sonnet-4-5)
# Swap to claude-haiku-4-5-20251001 for faster/cheaper if needed
# CLAUDE_MODEL=claude-sonnet-4-5


# ─── GOOGLE DRIVE ────────────────────────────────────────────
# Path to service account JSON key (relative to bot.py, or absolute)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Shared Drive ID — last segment of your Shared Drive URL:
#   drive.google.com/drive/folders/YOUR_DRIVE_ID_HERE
SHARED_DRIVE_ID=your-shared-drive-id-here
